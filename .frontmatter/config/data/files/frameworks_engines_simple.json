{
  "$schema": "https://frontmatter.codes/config/data.files.schema.json",
  "id": "frameworks_engines_simple",
  "title": "Frameworks & Engines Data",
  "file": "data/frameworks_engines.json",
  "labelField": "key",
  "schema": {
    "title": "Framework",
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "title": "Nom du framework/moteur"
      },
      "experience": {
        "type": "number",
        "title": "Expérience (en années)",
        "description": "1 = 1 an, 0.5 = 6 mois"
      },
      "iconPath": {
        "type": "string",
        "title": "Chemin vers l'icône SVG",
        "description": "Chemin relatif depuis le dossier static/ (ex: images/technologies/Unity.svg)"
      },
      "color": {
        "type": "string",
        "title": "Couleur",
        "widget": "colorPicker"
      },
      "displayedInPortfolio": {
        "type": "boolean",
        "title": "Affiché dans le portfolio"
      }
    },
    "required": [
      "name",
      "experience",
      "displayedInPortfolio"
    ]
  }
}
      },
      "category": {
        "type": "string",
        "title": "Catégorie",
        "enum": [
          "Management",
          "Development",
          "Design",
          "Art",
          "Animation",
          "Audio",
          "Level Design",
          "Assets",
          "UI/UX",
          "Support",
          "QA",
          "VFX",
          "Tools",
          "Community",
          "Marketing"
        ]
      },
      "icon": {
        "type": "string",
        "title": "Icône (emoji)"
      }
    }
  }
}
